# Database
POSTGRES_USER=mantle
POSTGRES_PASSWORD=mantle_secret
POSTGRES_DB=mantle_ems
DATABASE_URL=postgresql+asyncpg://mantle:mantle_secret@postgres:5432/mantle_ems

# Redis
REDIS_URL=redis://redis:6379/0

# JWT - use a strong random secret in production
# For RS256 production: generate RSA keypair and store as JWT_PRIVATE_KEY / JWT_PUBLIC_KEY
SECRET_KEY=change-me-use-a-strong-random-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Uploads
UPLOADS_DIR=/app/uploads

# Firebase (optional - push notifications)
# Set to path of your Firebase service account JSON file
# FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json

# Seed data
RUN_SEED=true
